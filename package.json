{
  "name": "deployment-script",
  "version": "1.0.0",
  "description": "Deployment automation with backup retention management",
  "main": "src/index.ts",
  "scripts": {
    "deploy": "tsx src/cli/deploy.ts",
    "backups": "tsx src/cli/backups.ts",
    "cleanup": "tsx src/cli/cleanup.ts",
    "ui:serve": "node dist/server/uiServer.js",
    "ui": "npm run build:backend && npm run ui:serve",
    "react:dev": "vite --mode development --port 5173",
    "web:build": "vite build",
    "web:build:debug": "vite build --mode development --sourcemap",
    "build": "npm run app:build",
    "start": "node dist/server/uiServer.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build:backend": "tsc -p tsconfig.node.json",
    "app:build": "npm run build:backend && npm run web:build",
    "app:start": "node dist/server/uiServer.js",
    "server:dev": "tsx --watch src/server/uiServer.ts",
    "pm2:start": "pm2 start ecosystem.config.js",
    "dev": "concurrently \"npm run react:dev\" \"npm run server:dev\""
  },
  "devDependencies": {
    "@types/node": "22.19.18",
    "autoprefixer": "10.4.19",
    "clsx": "2.1.1",
    "concurrently": "9.2.1",
    "framer-motion": "12.38.0",
    "lucide-react": "1.14.0",
    "postcss": "8.4.38",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "class-variance-authority": "0.7.1",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss-animate": "1.0.7",
    "vite": "8.0.11",
    "xlsx": "^0.18.5"
  }
}
